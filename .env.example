# ============================================
# AI Construction Copilot - Environment Example
# Copy file này thành .env và điền giá trị thật.
# KHÔNG commit file .env lên git.
# ============================================

# --- Database (Neon PostgreSQL) ---
# Lấy từ https://neon.tech -> Project -> Connection string
# Dán y nguyên, nhớ để ?sslmode=require ở cuối.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# --- AI ---
# mock   = chạy UI đầy đủ bằng dữ liệu mẫu, KHÔNG gọi OpenAI (không tốn tiền).
# openai = gọi OpenAI thật, cần OPENAI_API_KEY hợp lệ.
AI_PROVIDER="mock"

# Chỉ cần khi AI_PROVIDER="openai". Không bao giờ expose key ra frontend.
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-5-mini"
